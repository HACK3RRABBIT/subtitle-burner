#!/bin/sh
set -e

APP_DIR=/opt/subtitleburner

if [ ! -d "$APP_DIR/venv" ]; then
    echo "Subtitle Burner: creating Python virtual environment..."
    python3 -m venv "$APP_DIR/venv"

    # gui_webview.py (Linux's GUI entry point - Windows now uses a native
    # PySide6 gui.py instead) needs pywebview/pystray to show a window at all -
    # including the first-run setup progress window itself - but the rest of
    # the app's dependencies (the multi-GB ML stack) are only installed later
    # by bootstrap.py on first launch. Pre-installing the lightweight GUI
    # framework here avoids a chicken-and-egg crash (gui_webview.py trying to
    # import webview before anything has installed it).
    echo "Subtitle Burner: installing GUI framework..."
    "$APP_DIR/venv/bin/pip" install --quiet pywebview pystray Pillow
fi

# This is a single-user desktop app: it stores its config, job data, and
# first-run dependency install (via bootstrap.py) under its own install
# directory, so that directory needs to be writable by whichever user runs
# it, not just root. On a shared multi-user machine, tighten this by hand
# afterwards (e.g. give one group ownership) - this opens it to all local
# users, which is fine for the single-user desktop case this targets.
chmod -R a+rwX "$APP_DIR"

echo ""
echo "Subtitle Burner installed to $APP_DIR."
echo "Launch it from your applications menu, or run: subtitleburner"
echo ""
echo "First launch downloads several GB of dependencies (PyTorch, speech"
echo "models) - make sure you have an internet connection and free disk space."

exit 0
